# Copy to .env and fill in. Never commit .env.
NODE_ENV=development
PORT=4000

# Origin allowed by CORS (the web-admin dev server)
WEB_ADMIN_ORIGIN=http://localhost:5173

# PostgreSQL — matches docker-compose.yml defaults
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/campus?schema=public

# Redis — matches docker-compose.yml defaults
REDIS_URL=redis://localhost:6379

# JWT — change to a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Internal service-to-service token (used by AI orchestrator → API)
SERVICE_TOKEN=change-me-internal-service-token
